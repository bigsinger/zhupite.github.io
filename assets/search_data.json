[{% assign counter = 0 %}
{% for post in site.posts %}
{% if post.title %}
{% if counter > 0 %},{% endif %}
{
  "title"   : {{ post.title | jsonify }},
  "url"     : "{{ site.url }}{{ post.url }}",
  "date"    : "{{ post.date | date: '%Y-%m-%d' }}",
  "tags"    : {{ post.tags | join: ', ' | jsonify }},
  "excerpt" : {{ post.excerpt | strip_html | strip_newlines | strip | truncate: 300 | jsonify }},
  "content" : {{ post.content | strip_html | strip_newlines | strip | truncate: 5000 | jsonify }}
}{% assign counter = counter | plus: 1 %}
{% endif %}
{% endfor %}]
